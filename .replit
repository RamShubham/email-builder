modules = ["nodejs-20", "web"]
[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8008
externalPort = 8008

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AI Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @usewaypoint/editor run vitedev"
waitForPort = 5000

[[workflows.workflow]]
name = "AI Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx server/index.ts"
waitForPort = 8008

[deployment]
deploymentTarget = "autoscale"
build = ["pnpm", "--filter", "@usewaypoint/editor", "run", "vitebuild"]
publicDir = "packages/editor/dist"
run = ["npx", "tsx", "server/index.ts"]

[userenv]

[userenv.shared]
TINYEMAIL_API_KEYS = "tk_live_192011f3e18b9796dce559c41b48e97a645d2ea76e443c5f"
