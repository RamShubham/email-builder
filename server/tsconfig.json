{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"rootDir": "./",
		"outDir": "./dist",
		"allowJs": false,
		"noEmit": false,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"types": ["node"],
		"strict": false,
		"noImplicitReturns": false,
		"noUnusedLocals": false
	},
	"include": ["./**/*.ts", "./**/*.tsx"],
	"exclude": ["dist", "node_modules"]
}
